# GPT Image 2 environment template.
# Copy this file to .env, then replace placeholders with your real key.
# Do not commit .env. 这里不要填写真实 key。

# Required for real image generation. Dry-run does not need it.
OPENAI_API_KEY=replace_with_your_openai_or_relay_key

# Official OpenAI:
OPENAI_BASE_URL=https://api.openai.com/v1

# Relay/proxy example:
# OPENAI_BASE_URL=https://your-relay.example.com/v1

# Requested default. If your account/relay does not expose it, override this.
OPENAI_IMAGE_MODEL=gpt-image-2

# Script defaults. Keep these unless your provider requires different values.
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_BACKGROUND=opaque
OPENAI_IMAGE_TIMEOUT=120
OPENAI_IMAGE_RETRIES=2

# Optional JSON object for relay-specific headers.
# Example: {"X-Relay-Project":"xhs-publisher"}
OPENAI_EXTRA_HEADERS={}
